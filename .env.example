# Database (REQUIRED)
# Must be set to a SQLite Cloud URL. The application always uses SQLite Cloud.
# Get your database URL from https://sqlitecloud.com dashboard, e.g.:
# DATABASE_URL=sqlitecloud://your-project.g6.sqlite.cloud:8860/your-db.sqlitecloud?apikey=YOUR_API_KEY
# Do not commit .env with real API keys.
#
DATABASE_URL=sqlitecloud://your-project.g6.sqlite.cloud:8860/your-db.sqlitecloud?apikey=YOUR_API_KEY

# OneDrive / Microsoft Graph
# Create an app at https://portal.azure.com → App registrations → New registration
# Supported account types: single tenant
# Platform: Single-page application (SPA); add http://localhost:3000 and production redirect URIs
# API permissions (delegated, admin consented):
#   Files.ReadWrite.All, Sites.ReadWrite.All, User.Read, offline_access
#
REACT_APP_ONEDRIVE_CLIENT_ID=your-azure-app-client-id
REACT_APP_ONEDRIVE_TENANT_ID=your-tenant-id
REACT_APP_ONEDRIVE_REDIRECT_URI=http://localhost:3000

# Corporate shared OneDrive (for Calcsheet proposal/execution folder automation)
# DRIVE_OWNER is the email of the OneDrive for Business account that hosts the shared
# proposal/execution folders. The driveId is resolved at runtime via Graph and cached.
REACT_APP_ONEDRIVE_DRIVE_OWNER=projects@your-domain.com
REACT_APP_ONEDRIVE_PROPOSAL_ROOT=00 Proposal/IO Proposal
REACT_APP_ONEDRIVE_EXECUTION_ROOT=01 Execution
